@model List<SmartRetailSystem.Models.Product>

    <div class="container mt-5">
        <h2>Products</h2>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Price (ZAR)</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        <a class="btn btn-primary" href="/Cart/Add/@item.Id">Add to Cart</a>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
